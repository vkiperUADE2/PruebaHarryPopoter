# ─────────────────────────────────────────
#  SUPABASE (PostgreSQL)
# ─────────────────────────────────────────
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=<anon-public-key>
SUPABASE_KEY=<anon-or-service-key-used-by-backend>
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>
# Conexión directa a Postgres (si la necesitás)
DATABASE_URL=postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres

# ─────────────────────────────────────────
#  CASSANDRA
# ─────────────────────────────────────────
CASSANDRA_HOSTS=127.0.0.1
CASSANDRA_PORT=9042
CASSANDRA_KEYSPACE=<keyspace>
CASSANDRA_USERNAME=<username>
CASSANDRA_PASSWORD=<password>
ASTRA_DB_URL=https://<database-id>-<region>.apps.astra.datastax.com
ASTRA_TOKEN=AstraCS:<token>
# Si usás Astra DB (Cassandra cloud):
# CASSANDRA_CLIENT_ID=<client-id>
# CASSANDRA_CLIENT_SECRET=<client-secret>
# CASSANDRA_TOKEN=AstraCS:<token>
# CASSANDRA_SECURE_BUNDLE_PATH=./secure-connect-bundle.zip

# ─────────────────────────────────────────
#  MONGODB ATLAS
# ─────────────────────────────────────────
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB_NAME=<database>

# ─────────────────────────────────────────
#  REDIS
# ─────────────────────────────────────────
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=<password>
REDIS_DB=0
# URL completa (alternativa a las variables anteriores)
REDIS_URL=redis://:<password>@127.0.0.1:6379/0
